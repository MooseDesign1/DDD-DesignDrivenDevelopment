{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash \".claude/hooks/ddd-version-check.sh\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash \".claude/hooks/ddd-statusline.sh\"",
    "padding": 2
  }
}
